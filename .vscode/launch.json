{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run F1 Dashboard (app.py)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}\\app.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "justMyCode": true,
      "env": {
        "PORT": "8050"
      }
    }
  ]
}
